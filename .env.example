# Copy this to backend/.env and frontend/.env.local
# Then fill in your actual values

# ─── BACKEND ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string
DATABASE_URL=postgresql://postgres:password@localhost:5432/clinical_assistant
REDIS_URL=redis://localhost:6379

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=clinical-audio
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com

# Transcription — get key at https://app.sarvam.ai
SARVAM_API_KEY=

# Transcription fallback — get key at https://platform.openai.com
OPENAI_API_KEY=

# Note generation — get key at https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Monitoring (optional)
SENTRY_DSN=
POSTHOG_API_KEY=

# ─── FRONTEND ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
